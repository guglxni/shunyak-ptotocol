# Algorand
SHUNYAK_APP_ID=
SHUNYAK_CONSENT_SOURCE=hybrid
SHUNYAK_IDENTITY_PROVIDER=digilocker
SHUNYAK_ZK_BACKEND=algoplonk
ALGOD_TOKEN=
ALGOD_SERVER=https://testnet-api.algonode.cloud
INDEXER_TOKEN=
INDEXER_SERVER=https://testnet-idx.algonode.cloud
SHUNYAK_ENABLE_TESTNET_TX=true
SHUNYAK_USDCA_ASA_ID=
SHUNYAK_SIGNER_BALANCE_WARN_MICROALGO=1000000

# DigiLocker (Setu sandbox)
SHUNYAK_DIGILOCKER_BASE_URL=https://dg-sandbox.setu.co
SHUNYAK_DIGILOCKER_REDIRECT_URL=https://shunyak-protocol.vercel.app/consent
SHUNYAK_DIGILOCKER_CLIENT_ID=
SHUNYAK_DIGILOCKER_CLIENT_SECRET=
SHUNYAK_DIGILOCKER_PRODUCT_INSTANCE_ID=
SHUNYAK_DIGILOCKER_TIMEOUT_SECONDS=15

# AlgoPlonk verifier integration
SHUNYAK_ALGOPLONK_VERIFY_APP_ID=
SHUNYAK_ALGOPLONK_VERIFY_METHOD_SIGNATURE=verify(byte[32][],byte[32][])bool
SHUNYAK_ALGOPLONK_REQUIRE_ONCHAIN_VERIFY=true
SHUNYAK_ALGOPLONK_SIMULATE_ONLY=false
SHUNYAK_CONSENT_REGISTER_METHOD_SIGNATURE=register_consent(byte[],byte[],byte[],byte[],uint64)void
SHUNYAK_CONSENT_REVOKE_METHOD_SIGNATURE=revoke_consent(byte[],byte[])void
SHUNYAK_CONSENT_REQUIRE_BOX_PARITY=true
SHUNYAK_STREAM_TICKET_TTL_SECONDS=90
SHUNYAK_STREAM_TICKET_SECRET=

# Agent wallet (TESTNET ONLY)
SHUNYAK_AGENT_MNEMONIC=
SHUNYAK_DEPLOYER_MNEMONIC=
SHUNYAK_CONSENT_REGISTRAR_MNEMONIC=

# Consent token signing key (required and must be non-default in deployed environments)
SHUNYAK_DEMO_SECRET=
SHUNYAK_ALLOW_INSECURE_DEMO_SECRET=false

# Agent execution API guardrails
SHUNYAK_REQUIRE_OPERATOR_AUTH=true
SHUNYAK_OPERATOR_TOKEN=
SHUNYAK_REQUIRE_EXECUTION_TOKEN=true
SHUNYAK_MAX_SETTLEMENT_MICROALGO=5000000
SHUNYAK_RATE_LIMIT_WINDOW_SECONDS=60
SHUNYAK_RATE_LIMIT_MAX_REQUESTS=20
SHUNYAK_RATE_LIMIT_MAX_PER_USER=8
SHUNYAK_RATE_LIMIT_SPEND_MICROALGO=20000000

# LiteLLM / BYOK defaults (can be overridden from UI on main page)
SHUNYAK_LLM_BYOK_ENABLED=false
SHUNYAK_LLM_PROVIDER=openai
SHUNYAK_LLM_MODEL=openai/gpt-4o-mini
SHUNYAK_LLM_API_BASE=
SHUNYAK_LLM_API_KEY=
SHUNYAK_LLM_API_VERSION=

# Optional provider-specific keys for Dolios inference router profiles
OPENROUTER_API_KEY=
OPENAI_API_KEY=
NOUS_API_KEY=
NVIDIA_API_KEY=

# Feature flags
DOLIOS_SANDBOX_DISABLED=true
DOLIOS_AIDLC_ENABLED=false
DOLIOS_AUDIT_LOG=/tmp/shunyak-audit.jsonl
SHUNYAK_REQUIRE_HARDENED=false
SHUNYAK_SETTLEMENT_ALLOW_MOCK_FALLBACK=false

# CORS (comma-separated, exact origins)
SHUNYAK_ALLOWED_ORIGINS=

# Integration testing (opt-in)
SHUNYAK_RUN_ONCHAIN_INTEGRATION=0

# Optional deployment convenience
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
